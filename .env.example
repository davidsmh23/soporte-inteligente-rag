# Embeddings (temporales): clave de Gemini para generar embeddings en indexado/busqueda.
EMBEDDING_API_KEY=

# Compatibilidad con despliegues antiguos (si usas GOOGLE_API_KEY, tambien funciona).
# GOOGLE_API_KEY=

# Seguridad MCP remoto (obligatorio para clientes Codex CLI).
MCP_BEARER_TOKEN=change-me

# Seguridad session-gateway.
# Formato recomendado: user1:token1,user2:token2
SESSION_USER_TOKENS=demo:demo-token
# Alternativa opcional para token compartido global:
# SESSION_SHARED_TOKEN=shared-token

# Valores sugeridos para Streamlit
DEFAULT_USER_ID=demo
DEFAULT_USER_TOKEN=demo-token

# Opcionales backend
# SIMILARITY_THRESHOLD=0.6
# EMBEDDING_MODEL=models/gemini-embedding-2
# LOOKUP_K=3
